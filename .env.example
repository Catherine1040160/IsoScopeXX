# Host paths (required)
DATA_PATH=/path/to/your/data
LOGS_PATH=/path/to/your/logs

# Training config (required)
YAML_CONFIG=filopodia_GHCL01
PRJ=default

# Additional training arguments (optional)
# For remote MLflow server, add: --tracking_uri http://<mlflow-host>:5003
# EXTRA_TRAIN_ARGS=--nocut --downbranch 2 --cropz 32

# Docker image PyTorch tag
PYTORCH_TAG=2.7.1-cuda11.8-cudnn9-runtime
# PYTORCH_TAG=2.8.0-cuda12.8-cudnn9-runtime

# MLflow allowed hosts (overrides the default: localhost:*,mlflow:*)
# MLFLOW_ALLOWED_HOSTS=localhost:*,mlflow:*,<server-ip>:*
